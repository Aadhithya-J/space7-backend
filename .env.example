# ── Server ──
PORT=5000
NODE_ENV=development

# ── PostgreSQL ──
DATABASE_URL=
DB_HOST=postgres
DB_PORT=5432
DB_USER=space7user
DB_PASSWORD=space7pass
DB_NAME=space7db

# ── Redis ──
REDIS_URL=
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ──
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# ── Cloudinary ──
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Brevo Transactional Email ──
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=Space7 <your_verified_sender@example.com>
BREVO_SENDER_NAME=Space7

# ── OTP ──
OTP_EXPIRY_SECONDS=300
